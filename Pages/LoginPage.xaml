<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MauiDotnet.Controls"
             x:Class="MauiDotnet.Pages.LoginPage"
             BackgroundColor="#0A1E46"
             NavigationPage.HasNavigationBar="False">

    <Grid ColumnDefinitions="Auto, *">
        
        <controls:Sidebar ActiveStep="2" Grid.Column="0" />

        <VerticalStackLayout Grid.Column="1" 
                             Padding="60" 
                             VerticalOptions="Center" 
                             Spacing="40"
                             HorizontalOptions="Center">
            
            <ActivityIndicator IsRunning="True" 
                               Color="#2563eb" 
                               HeightRequest="80" 
                               WidthRequest="80" />

            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="Sign-in Required" 
                       FontSize="28" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalTextAlignment="Center"/>
                
                <Label Text="Please complete the Microsoft authentication in the browser window that just opened."
                       FontSize="16"
                       TextColor="#B0C4DE"
                       HorizontalTextAlignment="Center"
                       MaxLines="2" />
            </VerticalStackLayout>

            <Button Text="Didn't see a window? Try again"
                    BackgroundColor="Transparent"
                    TextColor="#2563eb"
                    FontSize="13"
                    Clicked="OnRetryClicked" />
            
        </VerticalStackLayout>

    </Grid>

</ContentPage>